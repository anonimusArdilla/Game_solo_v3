FLAVOR=prod
# Allowed values: dev|prod. Used for validation strictness and logging.

# Feature flags. Set to true only after providing all required service credentials.
FEATURE_FIREBASE=false
FEATURE_ADS=false

# Remote-config minimum fetch interval (seconds). Higher values reduce network and battery usage.
REMOTE_CONFIG_MIN_FETCH_INTERVAL_SECONDS=3600

# Backend base URL for cloud features (leaderboards, cloud saves, remote config).
BACKEND_BASE_URL=https://your-backend.example.com/api

# Optional: backend project/app identifier when using a self-hosted backend.
BACKEND_PROJECT_ID=your-backend-project-id

# Firebase project ID (from Firebase Console → Project settings).
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase app IDs (from Firebase Console → Project settings → Your apps).
FIREBASE_APP_ID_ANDROID=your-android-app-id
FIREBASE_APP_ID_IOS=your-ios-app-id

# Firebase Web API key (from Firebase Console → Project settings → General).
FIREBASE_API_KEY=your-firebase-api-key

# AdMob app IDs (from AdMob → Apps → App settings). Required for Google Mobile Ads SDK.
ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~zzzzzzzzzz

# Ad unit IDs (from AdMob → Ad units).
ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-xxxxxxxxxxxxxxxx/rrrrrrrrrr
ADMOB_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-xxxxxxxxxxxxxxxx/iiiiiiiiii

# Sentry DSN for crash reporting (Sentry project settings).
SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/0000000

